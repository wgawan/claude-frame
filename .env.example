# Required: password for the web UI
CLAUDE_PASSWORD=

# Optional: port (default: 3000)
# CLAUDE_PORT=3000

# Optional: URL to embed in the preview panel
# CLAUDE_IFRAME_URL=http://localhost:5173

# Optional: prefix prepended to every prompt (e.g. "The user is non-technical. Speak in plain terms.")
# CLAUDE_PROMPT_PREFIX=
